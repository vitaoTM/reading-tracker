<div class="w-full">
  <div class="mb-8">
    <h1 class="h1">Reading Habits</h1>
    <p class="mt-2 text-lg text-gray-600">Track your reading sessions and streaks.</p>
  </div>

  <%# Stats %>
  <div class="grid grid-cols-2 gap-6 sm:grid-cols-4 mb-8">
    <div class="card p-6 text-center">
      <p class="text-3xl font-bold text-indigo-600"><%= @stats[:current_streak] %></p>
      <p class="text-sm text-gray-600 mt-1">Day streak</p>
    </div>
    <div class="card p-6 text-center">
      <p class="text-3xl font-bold text-indigo-600"><%= @stats[:total_pages] %></p>
      <p class="text-sm text-gray-600 mt-1">Pages (30d)</p>
    </div>
    <div class="card p-6 text-center">
      <p class="text-3xl font-bold text-indigo-600"><%= @stats[:total_minutes] %></p>
      <p class="text-sm text-gray-600 mt-1">Minutes (30d)</p>
    </div>
    <div class="card p-6 text-center">
      <p class="text-3xl font-bold text-indigo-600"><%= @stats[:days_active] %></p>
      <p class="text-sm text-gray-600 mt-1">Days active (30d)</p>
    </div>
  </div>

  <%# Heatmap %>
  <div class="card p-6 mb-8">
    <h2 class="text-base font-semibold text-gray-900 mb-4">Last 90 days</h2>
    <div class="flex flex-wrap gap-1">
      <% (90.days.ago.to_date..Date.current).each do |date| %>
        <% minutes = @heatmap[date] || 0 %>
        <% intensity = case minutes when 0 then "bg-gray-100" when 1..20 then "bg-indigo-200" when 21..45 then "bg-indigo-400" else
"bg-indigo-600" end %>
        <div class="w-3 h-3 rounded-sm <%= intensity %>" title="<%= date.strftime('%b %d') %>: <%= minutes %> min"></div>
      <% end %>
    </div>
  </div>

  <%# Log session form %>
  <div class="card p-6 mb-8">
    <h2 class="text-base font-semibold text-gray-900 mb-4">Log a session</h2>
    <%= form_with url: reading_sessions_path, scope: :reading_session, class: "grid grid-cols-2 gap-4 sm:grid-cols-4" do |f| %>
      <div>
        <%= f.label :read_on, "Date", class: "label" %>
        <%= f.date_field :read_on, value: Date.current, class: "form-input w-full" %>
      </div>
      <div>
        <%= f.label :duration_minutes, "Minutes", class: "label" %>
        <%= f.number_field :duration_minutes, min: 1, class: "form-input w-full" %>
      </div>
      <div>
        <%= f.label :pages_read, "Pages", class: "label" %>
        <%= f.number_field :pages_read, min: 0, class: "form-input w-full" %>
      </div>
      <div>
        <%= f.label :book_id, "Book", class: "label" %>
        <%= f.collection_select :book_id, Current.user.books, :id, :title, { include_blank: "— optional —" }, { class: "form-input
w-full" } %>
      </div>
      <div class="col-span-2 sm:col-span-4">
        <%= f.submit "Log session", class: "btn-primary" %>
      </div>
    <% end %>
  </div>

  <%# Recent sessions %>
  <div class="card p-6">
    <h2 class="text-base font-semibold text-gray-900 mb-4">Recent sessions</h2>
    <% if @recent.empty? %>
      <p class="text-sm text-gray-500">No sessions logged yet.</p>
    <% else %>
      <ul class="divide-y divide-gray-100">
        <% @recent.each do |session| %>
          <li class="flex items-center justify-between py-3">
            <div>
              <p class="text-sm font-medium text-gray-900"><%= session.read_on.strftime("%b %d, %Y") %></p>
              <p class="text-xs text-gray-500">
                <%= [ ("#{session.duration_minutes} min" if session.duration_minutes), ("#{session.pages_read} pages" if
session.pages_read) ].compact.join(" · ") %>
                <% if session.book %>· <%= session.book.title %><% end %>
              </p>
            </div>
            <%= button_to "Remove", reading_session_path(session), method: :delete, class: "text-xs text-red-500 hover:text-red-700" %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>
</div>
