<div id="<%= dom_id(loan) %>"
     class="flex items-center justify-between
            p-4 rounded-xl border border-slate-100
            hover:border-slate-200 bg-slate-50/50 transition duration-150">
  <div class="min-w-0 flex-1 pr-4">
    <p class="text-sm font-semibold text-slate-900 truncate"><%= loan.display_title %></p>
    <p class="text-xs text-slate-500 mt-0.5">
      <% if loan.lent? %>
        Lent to <span class="font-semibold text-indigo-600"><%= loan.counterparty_name %></span>
      <% else %>
        Borrowed from <span class="font-semibold text-emerald-600"><%= loan.counterparty_name %></span>
      <% end %>
      · <%= loan.loaned_on.strftime("%b %d, %Y") %>
    </p>
    <% if loan.notes.present? %>
      <p class="text-xs text-slate-400 italic mt-1 truncate"><%= loan.notes %></p>
    <% end %>
  </div>
  <div class="flex items-center gap-2">
    <%= button_to "Mark Returned", loan_path(loan),
                    method: :patch,
                    params: { loan: { returned_on: Date.current } },
                    class: "inline-flex items-center justify-center rounded-md bg-white px-2.5 py-1.5 text-xs font-
semibold text-slate-700 ring-1 ring-inset ring-slate-300 hover:bg-slate-50 transition cursor-pointer" %>
    <%= button_to loan_path(loan),
                    method: :delete,
                    class: "p-1.5 rounded-md
                            text-slate-400 hover:text-red-500 
                            hover:bg-red-50 transition cursor-pointer",
                    data: { turbo_confirm: "Delete this loan record?" } do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138
21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
      </svg>
    <% end %>
  </div>
</div>
