<div class="w-full max-w-5xl mx-auto">
  <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="h1">Book Loans</h1>
      <p class="mt-2 text-lg text-slate-600">Keep track of books you've lent to friends or borrowed from others.</p>
    </div>
    <%= turbo_frame_tag "loan_form" do %>
      <%= link_to "Record a Loan", new_loan_path, class: "btn-primary shadow-indigo-100 font-semibold" %>
    <% end %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
    <%# Lent Section %>
    <div class="card p-6 flex flex-col">
      <div class="flex items-center justify-between pb-4 border-b border-slate-100 mb-6">
        <h2 class="text-xl font-bold text-slate-800 flex items-center gap-2">
          <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-
8" />
          </svg>
          Lent to Others
        </h2>
        <span id="lent_count_badge" class="inline-flex items-center rounded-full bg-indigo-50 px-2.5 py-0.5 text-xs
font-semibold text-indigo-700 ring-1 ring-inset ring-indigo-700/10">
          <%= @lent.count %> Active
        </span>
      </div>

      <div id="lent_loans_container" class="flex-1 flex flex-col">
        <% if @lent.empty? %>
          <%= render "loans/lent_empty_state" %>
        <% else %>
          <div id="lent_loans_list" class="space-y-4 flex-1">
            <%= render partial: "loans/loan", collection: @lent %>
          </div>
        <% end %>
      </div>
    </div>

    <%# Borrowed Section %>
    <div class="card p-6 flex flex-col">
      <div class="flex items-center justify-between pb-4 border-b border-slate-100 mb-6">
        <h2 class="text-xl font-bold text-slate-800 flex items-center gap-2">
          <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 13l-7 7-7-7m14-6l-7 7-7-7"
/>
          </svg>
          Borrowed from Others
        </h2>
        <span id="borrowed_count_badge" class="inline-flex items-center rounded-full bg-emerald-50 px-2.5 py-0.5 text-
xs font-semibold text-emerald-700 ring-1 ring-inset ring-emerald-700/10">
          <%= @borrowed.count %> Active
        </span>
      </div>

      <div id="borrowed_loans_container" class="flex-1 flex flex-col">
        <% if @borrowed.empty? %>
          <%= render "loans/borrowed_empty_state" %>
        <% else %>
          <div id="borrowed_loans_list" class="space-y-4 flex-1">
            <%= render partial: "loans/loan", collection: @borrowed %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# History Section %>
  <div class="card p-6">
    <div class="pb-4 border-b border-slate-100 mb-6">
      <h2 class="text-xl font-bold text-slate-800 flex items-center gap-2">
        <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9
0 0118 0z" />
        </svg>
        History
      </h2>
    </div>

    <div id="history_content">
      <% if @history.empty? %>
        <%= render "loans/history_empty_state" %>
      <% else %>
        <%= render "loans/history_table", history: @history %>
      <% end %>
    </div>
  </div>
</div>
