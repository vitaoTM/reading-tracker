<div class="w-full max-w-5xl mx-auto">
  <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="h1">Book Loans</h1>
      <p class="mt-2 text-lg text-slate-600">Keep track of books you've lent to friends or borrowed from others.</p>
    </div>
    <%= link_to "Record a Loan", new_loan_path, class: "btn-primary shadow-indigo-100 font-semibold" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
    <%# Lent Section %>
    <div class="card p-6 flex flex-col">
      <div class="flex items-center justify-between pb-4 border-b border-slate-100 mb-6">
        <h2 class="text-xl font-bold text-slate-800 flex items-center gap-2">
          <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
          </svg>
          Lent to Others
        </h2>
        <span class="inline-flex items-center rounded-full bg-indigo-50 px-2.5 py-0.5 text-xs font-semibold text-indigo-700 ring-1 ring-inset ring-indigo-700/10">
          <%= @lent.count %> Active
        </span>
      </div>

      <% if @lent.empty? %>
        <div class="flex-1 flex flex-col items-center justify-center py-10 text-center">
          <svg class="w-12 h-12 text-slate-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
          <p class="text-slate-500 text-sm font-medium">No books lent out right now.</p>
        </div>
      <% else %>
        <div class="space-y-4 flex-1">
          <% @lent.each do |loan| %>
            <div class="flex items-center justify-between p-4 rounded-xl border border-slate-100 hover:border-slate-200 bg-slate-50/50 transition duration-150">
              <div class="min-w-0 flex-1 pr-4">
                <p class="text-sm font-semibold text-slate-900 truncate"><%= loan.display_title %></p>
                <p class="text-xs text-slate-500 mt-0.5">
                  Lent to <span class="font-semibold text-indigo-600"><%= loan.counterparty_name %></span>
                  · <%= loan.loaned_on.strftime("%b %d, %Y") %>
                </p>
                <% if loan.notes.present? %>
                  <p class="text-xs text-slate-400 italic mt-1 truncate"><%= loan.notes %></p>
                <% end %>
              </div>
              <div class="flex items-center gap-2">
                <%= button_to "Mark Returned", loan_path(loan),
                              method: :patch,
                              params: { loan: { returned_on: Date.current } },
                              class: "inline-flex items-center justify-center rounded-md bg-white px-2.5 py-1.5 text-xs font-semibold text-slate-700 ring-1 ring-inset ring-slate-300 hover:bg-slate-50 transition cursor-pointer" %>
                <%= button_to loan_path(loan),
                              method: :delete,
                              class: "p-1.5 rounded-md text-slate-400 hover:text-red-500 hover:bg-red-50 transition cursor-pointer",
                              data: { turbo_confirm: "Delete this loan record?" } do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Borrowed Section %>
    <div class="card p-6 flex flex-col">
      <div class="flex items-center justify-between pb-4 border-b border-slate-100 mb-6">
        <h2 class="text-xl font-bold text-slate-800 flex items-center gap-2">
          <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 13l-7 7-7-7m14-6l-7 7-7-7" />
          </svg>
          Borrowed from Others
        </h2>
        <span class="inline-flex items-center rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-semibold text-emerald-700 ring-1 ring-inset ring-emerald-700/10">
          <%= @borrowed.count %> Active
        </span>
      </div>

      <% if @borrowed.empty? %>
        <div class="flex-1 flex flex-col items-center justify-center py-10 text-center">
          <svg class="w-12 h-12 text-slate-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 4H6a2 2 0 00-2 2v12a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-2m-4-1v8m0 0l3-3m-3 3L9 8m-5 5h2.586a1 1 0 01.707.293l2.414 2.414a1 1 0 00.707.293h3.172a1 1 0 00.707-.293l2.414-2.414a1 1 0 01.707-.293H20" />
          </svg>
          <p class="text-slate-500 text-sm font-medium">No books borrowed right now.</p>
        </div>
      <% else %>
        <div class="space-y-4 flex-1">
          <% @borrowed.each do |loan| %>
            <div class="flex items-center justify-between p-4 rounded-xl border border-slate-100 hover:border-slate-200 bg-slate-50/50 transition duration-150">
              <div class="min-w-0 flex-1 pr-4">
                <p class="text-sm font-semibold text-slate-900 truncate"><%= loan.display_title %></p>
                <p class="text-xs text-slate-500 mt-0.5">
                  Borrowed from <span class="font-semibold text-emerald-600"><%= loan.counterparty_name %></span>
                  · <%= loan.loaned_on.strftime("%b %d, %Y") %>
                </p>
                <% if loan.notes.present? %>
                  <p class="text-xs text-slate-400 italic mt-1 truncate"><%= loan.notes %></p>
                <% end %>
              </div>
              <div class="flex items-center gap-2">
                <%= button_to "Mark Returned", loan_path(loan),
                              method: :patch,
                              params: { loan: { returned_on: Date.current } },
                              class: "inline-flex items-center justify-center rounded-md bg-white px-2.5 py-1.5 text-xs font-semibold text-slate-700 ring-1 ring-inset ring-slate-300 hover:bg-slate-50 transition cursor-pointer" %>
                <%= button_to loan_path(loan),
                              method: :delete,
                              class: "p-1.5 rounded-md text-slate-400 hover:text-red-500 hover:bg-red-50 transition cursor-pointer",
                              data: { turbo_confirm: "Delete this loan record?" } do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%# History Section %>
  <div class="card p-6">
    <div class="pb-4 border-b border-slate-100 mb-6">
      <h2 class="text-xl font-bold text-slate-800 flex items-center gap-2">
        <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        History
      </h2>
    </div>

    <% if @history.empty? %>
      <div class="text-center py-8">
        <p class="text-slate-500 text-sm font-medium">No returned loans in your history yet.</p>
      </div>
    <% else %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200">
          <thead>
            <tr>
              <th class="text-left text-xs font-semibold text-slate-500 uppercase tracking-wider pb-3">Book</th>
              <th class="text-left text-xs font-semibold text-slate-500 uppercase tracking-wider pb-3">Activity</th>
              <th class="text-left text-xs font-semibold text-slate-500 uppercase tracking-wider pb-3">Person</th>
              <th class="text-left text-xs font-semibold text-slate-500 uppercase tracking-wider pb-3">Dates</th>
              <th class="relative pb-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @history.each do |loan| %>
              <tr class="hover:bg-slate-50/50 transition">
                <td class="py-4 text-sm font-semibold text-slate-900"><%= loan.display_title %></td>
                <td class="py-4 text-sm">
                  <% if loan.lent? %>
                    <span class="inline-flex items-center rounded-md bg-indigo-50 px-2 py-1 text-xs font-medium text-indigo-700 ring-1 ring-inset ring-indigo-700/10">Lent</span>
                  <% else %>
                    <span class="inline-flex items-center rounded-md bg-emerald-50 px-2 py-1 text-xs font-medium text-emerald-700 ring-1 ring-inset ring-emerald-700/10">Borrowed</span>
                  <% end %>
                </td>
                <td class="py-4 text-sm text-slate-600 font-medium"><%= loan.counterparty_name %></td>
                <td class="py-4 text-xs text-slate-500">
                  <p>Out: <%= loan.loaned_on.strftime("%b %d, %Y") %></p>
                  <p class="mt-0.5 text-slate-400">In: <%= loan.returned_on&.strftime("%b %d, %Y") %></p>
                </td>
                <td class="py-4 text-right text-sm">
                  <%= button_to loan_path(loan),
                                method: :delete,
                                class: "text-slate-400 hover:text-red-500 hover:bg-red-50 p-1.5 rounded-md inline-block transition cursor-pointer",
                                data: { turbo_confirm: "Delete this history record?" } do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>
