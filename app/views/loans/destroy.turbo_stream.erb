<%= turbo_stream.remove dom_id(@loan) %>

<% if @loan.returned_on.nil? %>
  <% if @loan.lent? %>
    <%= turbo_stream.update "lent_count_badge" do %>
      <%= @lent_count %> Active
    <% end %>
    <% if @lent_count == 0 %>
      <%= turbo_stream.replace "lent_loans_container", partial: "loans/lent_empty_state" %>
    <% end %>
  <% else %>
    <%= turbo_stream.update "borrowed_count_badge" do %>
      <%= @borrowed_count %> Active
    <% end %>
    <% if @borrowed_count == 0 %>
      <%= turbo_stream.replace "borrowed_loans_container", partial: "loans/borrowed_empty_state" %>
    <% end %>
  <% end %>
<% else %>
  <% if @history_count == 0 %>
    <%= turbo_stream.replace "history_content", partial: "loans/history_empty_state" %>
  <% end %>
<% end %>

<%= turbo_stream.prepend "flash", partial: "shared/flash" %>
