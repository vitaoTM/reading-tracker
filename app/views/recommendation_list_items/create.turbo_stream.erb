<%= turbo_stream.remove "empty_list_state" %>
<%= turbo_stream.append "recommendation_list_items", 
                        partial: "recommendation_list_items/recommendation_list_item", 
                        locals: { recommendation_list_item: @item } %>
<%= turbo_stream.replace "add_book_form_container", 
                         partial: "recommendation_list_items/add_book_form",
                         locals: { list: @list } %>
<%= turbo_stream.prepend "flash", partial: "shared/flash" %>
