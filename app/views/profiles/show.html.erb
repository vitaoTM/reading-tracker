<div class="w-full max-w-4xl mx-auto space-y-8">
  <div class="w-14 h-14 rounded-full bg-indigo-100 flex items-center justify-center text-2xl font-bold text-indigo-600">
    <%= @user.username.first.upcase %>
  </div>
  <div>
    <h1><%= @user.username %></h1>
    <p><%= @user.bio %></p>
  </div>
</div>

<div class="grid grid-cols-3 gap-4">
  <div class="card p-4 text-center">
    <p class="text-2xl font-bold text-indigo-600"><%= @stats[:total_pages] %></p>
    <p class="text-xs text-slate-500 mt-1">Pages (30 days)</p>
  </div>
  <div class="card p-4 text-center">
    <p class="text-2xl font-bold text-indigo-600"><%= @stats[:current_streak] %></p>
    <p class="text-xs text-slate-500 mt-1">Day streak</p>
  </div>
  <div class="card p-4 text-center">
    <p class="text-2xl font-bold text-indigo-600"><%= @user.finished_books.count %></p>
    <p class="text-xs text-slate-500 mt-1">Books finished</p>
  </div>

  <% if @reading.any? %>
    <div class="card p-6">
      <h2 class="font-bold text-lg mb-4">Currently Reading</h2>
      <ul class="space-y-2">
        <% @reading.each do |book| %>
          <li class="flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-green-400 shrink-0"><%= link_to book.title, book, class: "font-medium hover:underline" %></span>
            <span class="text-slate-400 text-sm"><%= book.author %></span>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>


<%# Favorite Books %>
<% if @favorites.any? %>
  <div class="card p-6">
    <h2 class="font-bold text-lg mb-4">Favorite Books</h2>
    <ol class="space-y-2">
      <% @favorites.each do |fav| %>
        <li class="flex items-center gap-3">
          <span class="font-mono text-slate-400 w-5"><%= fav.position %>.</span>
          <%= link_to fav.book.title, fav.book, class: "font-medium hover:underline" %>
          <span class="text-slate-400 text-sm"><%= fav.book.author %></span>
        </li>
      <% end %>
    </ol>
  </div>
<% end %>

<%# Public Recommendation Lists %>
<% if @public_lists.any? %>
  <div class="card p-6">
    <h2 class="font-bold text-lg mb-4">Reading Lists</h2>
    <div class="space-y-4">
      <% @public_lists.each do |list| %>
        <div>
          <h3 class="font-semibold"><%= link_to list.title, list, class: "hover:underline" %></h3>
          <p class="text-slate-500 text-sm"><%= list.items.size %> books</p>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# World Map %>
<% if @map_data.any? %>
  <div class="card p-6">
    <h2 class="font-bold text-lg mb-4">Reading Map · <%= @map_data.size %> countries</h2>
    <div class="flex flex-wrap gap-2">
      <% @map_data.each do |code, color| %>
        <span class="px-3 py-1 rounded-full text-xs font-semibold text-white"
              style="background-color: <%= color || '#4f86c6' %>">
          <%= code %>
        </span>
      <% end %>
    </div>
  </div>
<% end %>

</div>
