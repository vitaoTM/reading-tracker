<div class="w-full max-w-6xl mx-auto space-y-8">
  <%# Profile Header Card %>
  <div class="card p-8 bg-gradient-to-r from-slate-50 to-indigo-50/30 border-slate-200/60 shadow-sm flex flex-col md:flex-row items-center gap-6">
    <div class="w-20 h-20 rounded-full bg-indigo-600 text-white flex items-center justify-center text-3xl font-black shadow-md shadow-indigo-100 shrink-0 select-none">
      <%= @user.username.first.upcase %>
    </div>
    <div class="text-center md:text-left space-y-2 flex-1">
      <h1 class="text-3xl font-black text-slate-900 tracking-tight"><%= @user.username %></h1>
      <% if @user.bio.present? %>
        <p class="text-slate-600 text-base max-w-2xl"><%= @user.bio %></p>
      <% else %>
        <p class="text-slate-400 text-sm italic">No bio provided yet.</p>
      <% end %>
    </div>
  </div>

  <%# Grid Layout %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <%# Main Left Column (2/3 width) %>
    <div class="lg:col-span-2 space-y-8">
      <%# Currently Reading %>
      <div class="card p-6">
        <h2 class="text-xl font-extrabold text-slate-900 mb-4 flex items-center gap-2">
          <span>📖</span> Currently Reading
        </h2>
        <% if @reading.any? %>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <% @reading.each do |book| %>
              <div class="p-4 rounded-xl border border-slate-100 bg-slate-50/50 hover:bg-slate-50 transition flex items-center gap-4">
                <div class="flex-1 min-w-0">
                  <%= link_to book.title, book, class: "font-semibold text-slate-800 hover:text-indigo-600 hover:underline truncate block" %>
                  <span class="text-xs text-slate-500 block">by <%= book.author %></span>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-slate-400 text-sm italic py-4">Not currently reading any books.</p>
        <% end %>
      </div>

      <%# Favorite Books %>
      <div class="card p-6">
        <h2 class="text-xl font-extrabold text-slate-900 mb-4 flex items-center gap-2">
          <span>⭐</span> Favorite Books
        </h2>
        <%= render partial: "favorite_books" %>
      </div>

      <%# Public Recommendation Lists %>
      <div class="card p-6">
        <h2 class="text-xl font-extrabold text-slate-900 mb-4 flex items-center gap-2">
          <span>📋</span> Public Lists
        </h2>
        <% if @public_lists.any? %>
          <%= render partial: "public_lists" %>
        <% else %>
          <p class="text-slate-400 text-sm italic py-4">No public recommendation lists shared.</p>
        <% end %>
      </div>

      <% if Current.user == @user %>
        <div class="card p-6">
          <h2 class="text-xl font-extrabold text-slate-900 mb-4 flex items-center gap-2">
            <span>📋</span> My Private Lists
          </h2>
          <% if @private_lists.any? %>
            <%= render partial: "private_lists" %>
          <% else %>
            <p class="text-slate-400 text-sm italic py-4">No private recommendation lists shared.</p>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Sidebar Right Column (1/3 width) %>
    <div class="space-y-8">
      <%# Stats Container %>
      <div class="card p-6 space-y-4">
        <h2 class="text-lg font-bold text-slate-950">Reading Stats</h2>
        <div class="grid grid-cols-2 gap-3">
          <div class="bg-slate-50/80 rounded-xl p-3 border border-slate-100 text-center">
            <p class="text-xl font-black text-indigo-600"><%= @stats[:total_pages] %></p>
            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-wider mt-1">Pages</p>
          </div>
          <div class="bg-slate-50/80 rounded-xl p-3 border border-slate-100 text-center">
            <p class="text-xl font-black text-indigo-600"><%= @stats[:current_streak] %></p>
            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-wider mt-1">Streak</p>
          </div>
          <div class="bg-slate-50/80 rounded-xl p-3 border border-slate-100 text-center">
            <p class="text-xl font-black text-indigo-600"><%= @user.finished_books.count %></p>
            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-wider mt-1">Finished</p>
          </div>
          <div class="bg-slate-50/80 rounded-xl p-3 border border-slate-100 text-center">
            <p class="text-xl font-black text-indigo-600"><%= format_duration(@lifetime_minutes) %></p>
            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-wider mt-1">Total Time</p>
          </div>
        </div>
      </div>

      <%# Map Data %>
      <div class="card p-6">
        <h2 class="text-lg font-bold text-slate-950 mb-3 flex items-center gap-2">
          <span>🗺️</span> Reading Map
        </h2>
        <% if @map_data.any? %>
          <p class="text-xs text-slate-500 mb-4"><%= @map_data.size %> <%= "country".pluralize(@map_data.size) %> marked on the map.</p>
          <div class="flex flex-wrap gap-1.5 max-h-40 overflow-y-auto pr-1">
            <% @map_data.each do |code, color| %>
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold text-white shadow-sm"
                    style="background-color: <%= color || '#4f86c6' %>">
                📍 <%= code %>
                <% if @books_per_country[code].to_i > 0 %>
                  <span class="opacity-75 text-[10px] font-normal"><%= @books_per_country[code] %></span>
                <% end %>
              </span>
            <% end %>
          </div>
        <% else %>
          <p class="text-slate-400 text-sm italic py-4">No countries marked on the map yet.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
