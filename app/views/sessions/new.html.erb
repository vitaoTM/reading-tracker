<div class="w-full max-w-md">
  <div class="card">
    <h1 class="h1 mb-6 text-center">Sign in</h1>

    <%= form_with url: session_url do |form| %>
      <div class="space-y-4">
        <div>
          <%= form.label :email_address, class: "block text-sm font-medium leading-6 text-gray-900" %>
          <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "you@example.com", value: params[:email_address], class: "form-input mt-2" %>
        </div>

        <div>
          <%= form.label :password, class: "block text-sm font-medium leading-6 text-gray-900" %>
          <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "••••••••", maxlength: 72, class: "form-input mt-2" %>
        </div>

        <div class="flex items-center justify-between">
          <div class="text-sm">
            <%= link_to "Forgot password?", new_password_path, class: "font-semibold text-indigo-600 hover:text-indigo-500" %>
          </div>
        </div>

        <div>
          <%= form.submit "Sign in", class: "btn-primary w-full" %>
        </div>
      </div>
    <% end %>

    <p class="mt-6 text-center text-sm text-gray-500">
      Don't have an account?
      <%= link_to "Sign up", new_registration_path, class: "font-semibold leading-6 text-indigo-600 hover:text-indigo-500" %>
    </p>
  </div>
</div>
