<div class="w-full max-w-3xl mx-auto">
  <div class="mb-8">
    <h1 class="h1">Most Recommended</h1>
    <p class="mt-2 text-lg text-slate-600">The most popular books currently curated across all lists.</p>
  </div>

  <div class="card p-6">
    <% if @books.any? %>
      <div class="divide-y divide-slate-100">
        <% @books.each_with_index do |book, idx| %>
          <div class="flex items-center justify-between py-4 first:pt-0 last:pb-0">
            <div class="min-w-0 flex-1 pr-4">
              <div class="flex items-center gap-2">
                <span class="font-mono text-sm text-slate-400 w-5"><%= idx + 1 %>.</span>
                <%= link_to book.title, book, class: "text-sm font-semibold text-slate-900 hover:text-indigo-600 transition" %>
              </div>
              <span class="text-xs text-slate-500 block ml-7">by <%= book.author %></span>
            </div>
            <span class="inline-flex items-center rounded-md bg-indigo-50 px-2.5 py-1 text-xs font-semibold text-indigo-700 ring-1 ring-inset ring-indigo-700/10">
              👍 Recs: <%= book.recommendation_count %>
            </span>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-8 text-slate-400 text-sm italic">
        No recommendations recorded yet.
      </div>
    <% end %>
  </div>
</div>
