<% content_for :title, @book.title %>

<%= turbo_frame_tag dom_id(@book) do %>
  <div class="w-full max-w-3xl">
    <div class="mb-8">
      <div class="flex items-center justify-between flex-wrap gap-4">
        <h1 class="h1"><%= @book.title %></h1>
        <div class="flex gap-x-3">
          <%= link_to "Edit", edit_book_path(@book), class: "btn-secondary" %>
          <%= link_to "Back to books", books_path, class: "btn-secondary" %>
        </div>
      </div>

      <%# Average rating summary %>
      <div class="flex items-center gap-2 mt-3">
        <% if @book.ratings_count > 0 %>
          <div class="flex items-center text-amber-400 text-lg">
            <% @book.cached_average_rating.round.times do %>★<% end %>
            <% (5 - @book.cached_average_rating.round).times do %>☆<% end %>
          </div>
          <span class="text-sm font-semibold text-slate-700"><%= @book.cached_average_rating %></span>
          <span class="text-sm text-slate-500">(<%= @book.ratings_count %> <%= "rating".pluralize(@book.ratings_count) %>)</span>
        <% else %>
          <span class="text-sm text-slate-500">No ratings yet</span>
        <% end %>
      </div>

      <%# Tags display %>
      <% if @book.tags.any? %>
        <div class="flex flex-wrap gap-2 mt-4">
          <% @book.tags.each do |tag| %>
            <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-semibold text-slate-600 ring-1 ring-inset ring-slate-500/10">
              #<%= tag.name %>
            </span>
          <% end %>
        </div>
      <% end %>
    </div>


    <div class="card">
      <div class="grid grid-cols-1 gap-x-8 gap-y-10 border-b border-gray-900/10 pb-12 md:grid-cols-3">
        <div>
          <h2 class="text-base font-semibold leading-7 text-gray-900">Book Details</h2>
          <p class="mt-1 text-sm leading-6 text-gray-600">Basic information about the book.</p>
        </div>

        <div class="md:col-span-2">
          <dl class="grid grid-cols-1 gap-x-6 gap-y-4 sm:grid-cols-2">
            <div class="border-t border-gray-100 pt-4">
              <dt class="text-sm font-medium leading-6 text-gray-900">Author</dt>
              <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0"><%= @book.author %></dd>
            </div>
            <div class="border-t border-gray-100 pt-4">
              <dt class="text-sm font-medium leading-6 text-gray-900">ISBN</dt>
              <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0"><%= @book.isbn.presence || "N/A" %></dd>
            </div>
            <div class="border-t border-gray-100 pt-4">
              <dt class="text-sm font-medium leading-6 text-gray-900">Published Year</dt>
              <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0"><%= @book.published_year %></dd>
            </div>
            <div class="border-t border-gray-100 pt-4">
              <dt class="text-sm font-medium leading-6 text-gray-900">Age Indicator</dt>
              <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0"><%= @book.age_indicator&.titleize || "All Ages" %></dd>
            </div>
            <div class="border-t border-gray-100 pt-4">
              <dt class="text-sm font-medium leading-6 text-gray-900">Language</dt>
              <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0"><%= @book.language %></dd>
            </div>
            <div class="border-t border-gray-100 pt-4">
              <dt class="text-sm font-medium leading-6 text-gray-900">Page Count</dt>
              <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0"><%= @book.page_count %></dd>
            </div>
            <div class="border-t border-gray-100 pt-4 sm:col-span-2">
              <dt class="text-sm font-medium leading-6 text-gray-900">Country of Origin</dt>
              <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0"><%= @book.country_of_origin %></dd>
            </div>
            <% if Current.user %>
              <div class="border-t border-gray-100 pt-4">
                <dt class="text-sm font-medium leading-6 text-gray-900">Time Logged</dt>
                <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0">
                  <%= format_duration(Current.user.reading_sessions.where(book: @book).sum(:duration_minutes)) %>
                </dd>
              </div>
            <% end %>
          </dl>
        </div>
      </div>

      <% if @book.description.present? %>
        <div class="mt-10">
          <h2 class="text-base font-semibold leading-7 text-gray-900">Description</h2>
          <div class="mt-4 text-sm leading-6 text-gray-700 prose prose-slate max-w-none">
            <%= simple_format @book.description %>
          </div>
        </div>
      <% end %>

      <div class="mt-10 pt-6 border-t border-gray-900/10 flex justify-end">
        <%= button_to "Destroy this book", @book, method: :delete, class: "btn-danger", data: { turbo_confirm: "Are you sure?" } %>
      </div>
    </div>
  <% end %>

  <%= render "reading_status" %>

  <%# Ratings and Reviews Section %>
  <div class="card mt-8">
    <h2 class="text-lg font-bold text-slate-900 mb-6">Ratings & Reviews</h2>

    <%# Rate this book form %>
    <div class="bg-slate-50 p-6 rounded-xl border border-slate-100 mb-8">
      <h3 class="text-sm font-semibold text-slate-800 mb-4">
        <%= @user_rating.new_record? ? "Rate and review this book" : "Update your rating & review" %>
      </h3>

      <%= form_with model: [@book, @user_rating], local: true, class: "space-y-4" do |f| %>
        <div>
          <%= f.label :score, "Score", class: "block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-2" %>
          <div class="flex gap-3">
            <% (1..5).each do |score| %>
              <label class="flex-1 flex flex-col items-center justify-center p-2 rounded-lg border border-slate-200 bg-white hover:bg-slate-50 cursor-pointer transition [&:has(input:checked)]:border-amber-500 [&:has(input:checked)]:bg-amber-50/30 [&:has(input:checked)]:text-amber-700 text-center">
                <%= f.radio_button :score, score, class: "sr-only" %>
                <span class="text-lg font-bold"><%= score %></span>
                <span class="text-[10px] text-amber-500 mt-0.5">★</span>
              </label>
            <% end %>
          </div>
        </div>

        <div>
          <%= f.label :review, "Written Review", class: "block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-1" %>
          <%= f.text_area :review, rows: 3, placeholder: "What did you think of this book?", class: "form-input bg-white" %>
        </div>

        <div class="flex justify-between items-center pt-2">
          <% unless @user_rating.new_record? %>
            <%= link_to "Remove Rating", book_rating_path(@book, @user_rating), data: { turbo_method: :delete, turbo_confirm: "Delete your rating?" }, class: "btn-danger" %>
          <% else %>
            <div></div>
          <% end %>
          <%= f.submit "Submit Review", class: "btn-primary bg-indigo-600 shadow-indigo-100 cursor-pointer" %>
        </div>
      <% end %>
    </div>

    <%# Reviews list %>
    <h3 class="text-sm font-bold text-slate-800 mb-4">All Reviews</h3>
    <% if @book.ratings.empty? || (@book.ratings.count == 1 && @book.ratings.first.new_record?) %>
      <p class="text-sm text-slate-500 italic">No reviews yet. Be the first to review this book!</p>
    <% else %>
      <div class="space-y-6">
        <% @book.ratings.includes(:user).each do |r| %>
          <% next if r.new_record? %>
          <div class="pb-6 border-b border-slate-100 last:border-0 last:pb-0">
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2">
                <span class="font-semibold text-sm text-slate-800"><%= r.user.email_address.split("@").first %></span>
                <% if r.user == Current.user %>
                  <span class="inline-flex items-center rounded-md bg-indigo-50 px-1.5 py-0.5 text-[10px] font-medium text-indigo-700 ring-1 ring-inset ring-indigo-600/10">You</span>
                <% end %>
              </div>
              <span class="text-xs text-slate-400"><%= r.updated_at.strftime("%b %d, %Y") %></span>
            </div>
            <div class="flex items-center text-amber-400 text-xs mb-2">
              <% r.score.times do %>★<% end %>
              <% (5 - r.score).times do %>☆<% end %>
            </div>
            <% if r.review.present? %>
              <p class="text-sm text-slate-600 whitespace-pre-line bg-slate-50/50 p-3 rounded-lg border border-slate-100/50"><%= r.review %></p>
            <% else %>
              <p class="text-xs text-slate-400 italic">Rated <%= r.score %>/5 stars (no written review)</p>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
