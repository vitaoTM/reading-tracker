<div class="w-full max-w-3xl mx-auto">
  <%= turbo_frame_tag dom_id(@list) do %>
    <div class="mb-8 flex flex-col gap-4 border-b border-slate-200 pb-6">
      <div class="flex items-center justify-between gap-4 flex-wrap gap-y-2">
        <h1 class="h1"><%= @list.title %></h1>
        <div class="flex items-center gap-3">
          <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold <%= @list.public? ?
  'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/10' : 'bg-slate-100 text-slate-600 ring-1 ring-slate-500/10' %>">
            <%= @list.public? ? "Public" : "Private" %>
          </span>
          <%= link_to "Edit List Details", edit_recommendation_list_path(@list), class: "btn-secondary text-sm" %>
        </div>
      </div>
      <p class="text-lg text-slate-600"><%= @list.description %></p>
      <span class="text-sm text-slate-400 font-medium">
        📚 <%= @list.items.size %> / <%= RecommendationList::MAX_ITEMS %> Books
      </span>
    </div>
  <% end %>

  <div class="card p-6 mb-8">
    <h2 class="text-base font-bold text-slate-900 mb-4">Books on this List</h2>

    <div id="recommendation_list_items" class="divide-y divide-slate-100">
      <% if @list.items.any? %>
        <%= render @list.items %>
      <% else %>
        <div id="empty_list_state" class="text-center py-8 text-slate-400 text-sm italic">
          This list is empty. Choose a book below to populate it.
        </div>
      <% end %>
    </div>
  </div>

  <%= render "recommendation_list_items/add_book_form", list: @list %>

  <div class="flex items-center gap-4">
    <%= button_to "Delete List", recommendation_list_path(@list), method: :delete,
          class: "btn-danger bg-red-50 text-red-600 ring-1 ring-red-600/10 hover:bg-red-100",
          data: { turbo_confirm: "Are you sure you want to delete this list?" } %>
  </div>
</div>
