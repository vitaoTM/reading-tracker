<h1 class="text-2xl font bold mb-2"><%= @list.title %></h1>
<p class="text-gray-600 mb-4"><%= @list.description %></p>

<% @list.items.each do |item| %>
  <div class="flex items-center gap-2 py-1">
    <span><%= item.position %>. <%= item.book.title %></span>
    <%= button_to "Remove", recommendation_list_recommendation_list_item_path(@list, item),
                   method: :delete, 
                   class: "text-xs text-red-500" %>
  </div>
<% end %>

<%= link_to "Edit", edit_recommendation_list_path(@list) %>
