<h1 class="text-2xl font-bold mb-2"><%= @list.title %></h1>
<p class="text-gray-600 mb-4"><%= @list.description %></p>
<p class="text-sm text-gray-400 mb-6"><%= @list.public? ? "Public" : "Private" %> · <%= @list.items.size %> / <%= RecommendationList::MAX_ITEMS %> books</p>

<% @list.items.each do |item| %>
  <div class="flex items-center gap-2 py-2 border-b">
    <span class="font-mono text-sm w-5 text-gray-400"><%= item.position %>.</span>
    <span class="flex-1 font-medium"><%= link_to item.book.title, book_path(item.book) %></span>
    <span class="text-gray-500 text-sm"><%= item.book.author %></span>
    <%= button_to "Remove",
          recommendation_list_recommendation_list_item_path(@list, item),
          method: :delete,
          class: "text-xs text-red-500 hover:text-red-700" %>
  </div>
<% end %>

<% if @list.items.size < RecommendationList::MAX_ITEMS %>
  <div class="mt-6 p-4 border rounded-lg bg-gray-50">
    <h3 class="font-semibold mb-3">Add a book</h3>
    <%= form_with url: recommendation_list_recommendation_list_items_path(@list), scope: :recommendation_list_item do |f| %>
      <div class="flex gap-2">
        <%= f.collection_select :book_id,
              Book.order(:title), :id, :title,
              { include_blank: "— choose a book —" },
              class: "border rounded px-2 py-1 flex-1" %>
        <%= f.hidden_field :position, value: @list.items.size + 1 %>
        <%= f.submit "Add", class: "bg-blue-600 text-white px-4 py-1 rounded hover:bg-blue-700" %>
      </div>
    <% end %>
  </div>
<% end %>

<div class="mt-6 flex gap-4">
  <%= link_to "Edit List", edit_recommendation_list_path(@list), class: "text-sm text-gray-500 hover:underline" %>
  <%= button_to "Delete List", recommendation_list_path(@list), method: :delete,
        class: "text-sm text-red-500 hover:underline",
        data: { turbo_confirm: "Delete this list?" } %>
</div>
