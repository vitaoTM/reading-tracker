<div id="<%= dom_id(list) %>" class="card p-6 flex flex-col justify-between hover:shadow-md transition">
  <div>
    <div class="flex items-center justify-between gap-2 mb-2">
      <%= link_to list.title, list, class: "text-lg font-bold text-slate-900 hover:text-indigo-600 hover:underline transition" %>
      <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold
        <%= list.public? ? 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/10' : 'bg-slate-100 text-slate-600 ring-1 ring-slate-500/10' %>">
        <%= list.public? ? "public" : "private" %>
      </span>
    </div>
    <p class="text-sm text-slate-500 mb-4 line-clamp-2"><%= list.description.presence || "no description provided." %></p>
  </div>
  <div class="pt-4 border-t border-slate-100 flex items-center justify-between text-xs text-slate-400 font-medium">
    <span>📚 <%= list.items.size %> <%= "book".pluralize(list.items.size) %></span>
    <%= link_to "view details →", list, class: "text-indigo-600 hover:underline" %>
  </div>
</div>
