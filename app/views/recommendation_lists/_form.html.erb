<%= form_with(model: list, class: "space-y-6") do |f| %>
  <% if list.errors.any? %>
    <div class="rounded-md bg-red-50 p-4 mb-4">
      <h3 class="text-sm font-medium text-red-800">
        <%= pluralize(list.errors.count, "error") %> prohibited this list from being saved:
      </h3>
      <ul class="mt-2 text-sm text-red-700 list-disc pl-5">
        <% list.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, class: "block text-sm font-semibold text-slate-700 mb-1" %>
    <%= f.text_field :title, class: "form-input", placeholder: "e.g., Summer Classics" %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-semibold text-slate-700 mb-1" %>
    <%= f.text_area :description, rows: 4, class: "form-input", placeholder: "Explain the theme of this recommendation list..." %>
  </div>

  <div class="relative flex items-start">
    <div class="flex h-6 items-center">
      <%= f.check_box :public, class: "h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600 cursor-pointer" %>
    </div>
    <div class="ml-3 text-sm leading-6">
      <%= f.label :public, "Make public", class: "font-semibold text-slate-900 cursor-pointer" %>
      <p class="text-xs text-slate-500">Allow other users to discover and browse this list.</p>
    </div>
  </div>

  <div class="pt-6 border-t border-slate-100 flex items-center justify-end gap-x-3">
    <%= link_to "Cancel", (list.persisted? ? list:  recommendation_lists_path), class: "btn-secondary" %>
    <%= f.submit class: "btn-primary cursor-pointer" %>
  </div>
<% end %>
