<h1 class="text-2xl font-bold mb-4">My Lists</h1>

<%= link_to "New List", new_recommendation_list_path,
            class: "btn" %>
<% @lists.each do |list| %>
  <div class="border p-3 my-2">
    <%= link_to list.title, list %> (<%= list.items.size %> books)
    <span class="text-xs text-gray-500"><%= list.public? ? "Public" : "Private" %></span>
  </div>
<% end %>
