<div class="w-full">
  <div class="mb-8">
    <h1 class="h1">My Library</h1>
    <p class="mt-2 text-lg text-gray-600">All the books you're tracking, neatly organized.</p>
  </div>

  <% if @entries.empty? %>
    <div class="text-center card py-12">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
      </svg>
      <h3 class="mt-2 text-sm font-semibold text-gray-900">Your library is empty</h3>
      <p class="mt-1 text-sm text-gray-500">
        Start by browsing for books and adding them to your list.
      </p>
      <div class="mt-6">
        <%= link_to "Browse Books", books_path, class: "btn-primary" %>
      </div>
    </div>
  <% else %>
    <div class="space-y-12">
      <% ReadingEntry.statuses.each_key do |status| %>
        <% if @entries[status].present? %>
          <section>
            <h2 class="text-2xl font-bold tracking-tight text-slate-800 border-b border-slate-200 pb-2 mb-6">
              <%= status.humanize %>
            </h2>
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
              <% @entries[status].each do |entry| %>
                <div class="card p-4 flex flex-col justify-between">
                  <div>
                    <%= link_to book_path(entry.book) do %>
                      <h3 class="text-lg font-bold text-slate-900 truncate"><%= entry.book.title %></h3>
                    <% end %>
                    <p class="text-sm text-slate-600 mb-3">by <%= entry.book.author %></p>
                  </div>
                  <div class="flex items-center gap-x-2 mt-4">
                    <%= form_with url: reading_entry_path(entry), 
                                  method: :patch,
                                  scope: :reading_entry,
                                  class: "flex-1" do |f| %>
                      <%= f.select :status, ReadingEntry.statuses.keys.map { |s| [s.humanize, s] }, { selected: entry.status }, { class: "form-input w-full", onchange: "this.form.submit()" } %>
                    <% end %>
                    <%= button_to "Remove", reading_entry_path(entry), method: :delete, class: "btn-danger", form_class: "flex-shrink-0", data: { turbo_confirm: "Remove from library?"} %>
                  </div>
                </div>
              <% end %>
            </div>
          </section>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
