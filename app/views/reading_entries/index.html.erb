<div class="w-full">
  <div class="mb-8">
    <h1 class="h1">My Library</h1>
    <p class="mt-2 text-lg text-gray-600">All the books you're tracking, neatly organized.</p>
  </div>

  <% if @entries.empty? %>
    <div class="text-center card py-12">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
      </svg>
      <h3 class="mt-2 text-sm font-semibold text-gray-900">Your library is empty</h3>
      <p class="mt-1 text-sm text-gray-500">
        Start by browsing for books and adding them to your list.
      </p>
      <div class="mt-6">
        <%= link_to "Browse Books", books_path, class: "btn-primary" %>
      </div>
    </div>
  <% else %>
    <div class="space-y-12">
      <% ReadingEntry.statuses.each_key do |status| %>
        <% if @entries[status].present? %>
          <section>
            <h2 class="text-2xl font-bold tracking-tight text-slate-800 border-b border-slate-200 pb-2 mb-6">
              <%= status.humanize %>
            </h2>
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
              <% @entries[status].each do |entry| %>
                <div class="card p-5 flex flex-col justify-between hover:shadow-md hover:-translate-y-0.5 transition duration-200 group">
                  <div>
                    <%= link_to book_path(entry.book) do %>
                      <h3 class="text-base font-bold text-slate-900 group-hover:text-indigo-600 transition truncate" title="<%= entry.book.title %>"><%= entry.book.title %></h3>
                    <% end %>
                    <p class="text-xs text-slate-500 mt-1 mb-2">by <%= entry.book.author %></p>
                  </div>
                  <div class="flex items-center justify-between gap-x-2 mt-4 pt-4 border-t border-slate-100">
                    <%= form_with url: reading_entry_path(entry), 
                                  method: :patch,
                                  scope: :reading_entry,
                                  class: "inline-block" do |f| %>
                      <%= f.select :status, ReadingEntry.statuses.keys.map { |s| [s.humanize, s] }, { selected: entry.status }, { class: "bg-slate-50 hover:bg-slate-100 text-slate-600 rounded-lg px-2.5 py-1.5 text-xs font-semibold focus:ring-2 focus:ring-indigo-500 focus:outline-none cursor-pointer transition border border-transparent hover:border-slate-200", onchange: "this.form.submit()" } %>
                    <% end %>
                    <%= button_to reading_entry_path(entry), method: :delete, class: "p-1.5 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition duration-150 cursor-pointer", form_class: "flex-shrink-0", data: { turbo_confirm: "Remove from library?"} do %>
                      <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                      </svg>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </section>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
