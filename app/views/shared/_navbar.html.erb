<header data-controller="mobile-nav"
        class="sticky top-0 z-50 w-full bg-slate-200 backdrop-blur-md border-b border-slate-200/80 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <div class="flex items-center gap-6">

        <%= link_to (authenticated? ? root_path : root_path), class: "flex items-center gap-2 text-indigo-600 font-black text-lg hover:opacity-95 transition" do %>
          <span>📚</span>
          <span class="bg-clip-text">Reading Tracker</span>
        <% end %>
        <% if authenticated? %>
          <nav class="hidden md:flex items-center gap-1.5">
            <%= link_to "My Library",
                library_path, 
                class: "text-slate-600 hover:text-indigo-600 
                        hover:bg-slate-50 px-3 py-2 rounded-lg 
                        text-sm font-semibold transition" %>
            <%= link_to "Favorite Book",
                favorites_path, 
                class: "text-slate-600 hover:text-indigo-600 
                        hover:bg-slate-50 px-3 py-2 rounded-lg 
                        text-sm font-semibold transition" %>
            <%= link_to "Discover", 
                books_path, 
                class: "text-slate-600 hover:text-indigo-600 
                        hover:bg-slate-50 px-3 py-2 
                        rounded-lg text-sm font-semibold transition" %>
            <%= link_to "Lists", 
                recommendation_lists_path, 
                class: "text-slate-600 hover:text-indigo-600 
                        hover:bg-slate-50 px-3 py-2 
                        rounded-lg text-sm font-semibold transition" %>
            <%= link_to "Want to Read",
                want_to_read_path, 
                class: "text-slate-600 hover:text-indigo-600 
                        hover:bg-slate-50 px-3 py-2 rounded-lg 
                        text-sm font-semibold transition" %>
            <%= link_to "Habits", 
                habits_path, 
                class: "text-slate-600 hover:text-indigo-600 
                        hover:bg-slate-50 px-3 py-2 rounded-lg text-sm
                        font-semibold transition" %>
            <%= link_to "Loans", 
                loans_path, 
                class: "text-slate-600 hover:text-indigo-600 
                        hover:bg-slate-50 px-3 py-2 
                        rounded-lg text-sm font-semibold transition" %>
            <%= link_to "Map", 
                map_path, 
                class: "text-slate-600 hover:text-indigo-600 
                        hover:bg-slate-50 px-3 py-2 
                        rounded-lg text-sm font-semibold transition" %>
          </nav>
        <% end %>
      </div>
      <div class="flex items-center gap-3">
        <% if authenticated? %>
          <span class="hidden sm:inline-block text-xs font-semibold text-slate-500 bg-slate-100 px-2.5 py-1 rounded-full">
            <%= link_to Current.user.username, profile_path(username: Current.user.username) %>
          </span>
          <%= button_to "Sign out", session_path, method: :delete, class: "text-slate-600 hover:text-red-600 hover:bg-red-50 px-3 py-2
    rounded-lg text-sm font-semibold transition cursor-pointer" %>
          <button data-action="mobile-nav#toggle"
                  class="md:hidden p-2 rounded-lg text-slate-600 hover:bg-slate-100 transition cursor-pointer"
                  aria-label="Toggle menu">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        <% else %>
          <%= link_to "Sign in", new_session_path, class: "text-slate-600 hover:text-indigo-600 px-3 py-2 text-sm font-semibold
    transition" %>
          <%= link_to "Sign up", new_registration_path, class: "btn-primary py-1.5 px-3 text-xs" %>
        <% end %>
      </div>
    </div>
  </div>
  <% if authenticated? %>
    <div class="hidden md:hidden border-t border-slate-300/50 py-2 space-y-1 px-4"
          data-mobile-nav-target="menu">
      <%= link_to "My Library",    library_path,      class: "block px-3 py-2 rounded-lg text-sm font-semibold
  text-slate-700 hover:bg-slate-100 hover:text-indigo-600 transition", data: { action: "mobile-nav#close" } %>
      <%= link_to "Favorite Book", favorites_path,    class: "block px-3 py-2 rounded-lg text-sm font-semibold
  text-slate-700 hover:bg-slate-100 hover:text-indigo-600 transition", data: { action: "mobile-nav#close" } %>
      <%= link_to "Discover",      books_path,        class: "block px-3 py-2 rounded-lg text-sm font-semibold
  text-slate-700 hover:bg-slate-100 hover:text-indigo-600 transition", data: { action: "mobile-nav#close" } %>
      <%= link_to "Want to Read",  want_to_read_path, class: "block px-3 py-2 rounded-lg text-sm font-semibold
  text-slate-700 hover:bg-slate-100 hover:text-indigo-600 transition", data: { action: "mobile-nav#close" } %>
      <%= link_to "Habits",        habits_path,       class: "block px-3 py-2 rounded-lg text-sm font-semibold
  text-slate-700 hover:bg-slate-100 hover:text-indigo-600 transition", data: { action: "mobile-nav#close" } %>
      <%= link_to "Loans",         loans_path,        class: "block px-3 py-2 rounded-lg text-sm font-semibold
  text-slate-700 hover:bg-slate-100 hover:text-indigo-600 transition", data: { action: "mobile-nav#close" } %>
      <%= link_to "Map",           map_path,          class: "block px-3 py-2 rounded-lg text-sm font-semibold
  text-slate-700 hover:bg-slate-100 hover:text-indigo-600 transition", data: { action: "mobile-nav#close" } %>
    </div>
  <% end %>
</header>
